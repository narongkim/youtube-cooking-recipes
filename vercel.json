{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/notion/v1/(.*)", "dest": "/api/notion-proxy?path=/v1/$1" },
    { "src": "/api/openai/v1/(.*)", "dest": "/api/openai-proxy?path=/v1/$1" },
    { "src": "/api/health", "dest": "/api/health" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
